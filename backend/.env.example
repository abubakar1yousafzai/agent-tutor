# AgentTutor Backend — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string (Neon or local Postgres)
# Use postgresql+asyncpg:// prefix for async SQLAlchemy
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# Application environment
APP_ENV=development

# CORS allowed origins (comma-separated)
# Include ChatGPT App origins for production
ALLOWED_ORIGINS=http://localhost:3000,https://chatgpt.com,https://chat.openai.com

# Phase 2 — Hybrid Intelligence (Google Gemini via OpenAI Agents SDK)
GEMINI_API_KEY=your_gemini_api_key_here
